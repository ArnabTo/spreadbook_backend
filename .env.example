# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production host (set on DigitalOcean)
# Example:
# DJANGO_ALLOWED_HOSTS=apibiz.hellobiz.net
# DJANGO_CSRF_TRUSTED_ORIGINS=https://apibiz.hellobiz.net

# Auth/permissions (DEV/DEMO ONLY)
# WARNING: Setting this to 1 disables API authentication and permission checks.
# Do NOT enable in production.
DJANGO_DISABLE_AUTH=0

# SaaS mode (recommended for production)
# When enabled, API requests are blocked if the user's company subscription is not active/trial.
# software_owner and reseller roles bypass this check.
DJANGO_ENFORCE_SUBSCRIPTION=0

# Subscription lifecycle defaults
# New companies default to a free trial for this many days.
DJANGO_TRIAL_DAYS=30

# After trial/renewal due date, allow usage for this many days before locking.
DJANGO_SUBSCRIPTION_GRACE_DAYS=15

# Send renewal/trial ending reminders N days before due date.
# Example: 5,3 means notify 5 days before and 3 days before.
DJANGO_SUBSCRIPTION_NOTICE_DAYS=5,3

# If behind a reverse proxy (nginx), enable this
DJANGO_USE_X_FORWARDED_PROTO=0

# Security (production defaults are applied when DJANGO_DEBUG=0)
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1

# Cookie SameSite (override if you need cross-site cookies)
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

# CORS/CSRF
# For Vite dev server:
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_CORS_ALLOW_ALL=0
DJANGO_CORS_ALLOW_CREDENTIALS=1

# Database
# Local default is SQLite (no env needed).
# Production recommended: Postgres via DATABASE_URL (DigitalOcean Managed DB).
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# DJANGO_DB_CONN_MAX_AGE=60
# DJANGO_DB_SSL_REQUIRE=1

# Email (use real SMTP in production)
DJANGO_EMAIL_BACKEND=
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=1
DJANGO_DEFAULT_FROM_EMAIL=rakibulto@gmail.com
DJANGO_SERVER_EMAIL=rakibulto@gmail.com

# Djoser
DJOSER_DOMAIN=localhost:8000

# Logging
DJANGO_LOG_LEVEL=INFO

# Demo passwords (DEV only). In production keep this OFF.
# When enabled, restaurant-login accepts role-based demo passwords like owner123/admin123/etc.
DJANGO_ALLOW_DEMO_PASSWORDS=0

# API rate limiting (OWASP) - optional
DJANGO_ENABLE_THROTTLING=0
DJANGO_THROTTLE_ANON=100/min
DJANGO_THROTTLE_USER=1000/min

# Cloudinary
CLOUD_NAME=
API_KEY=
API_SECRET=
